# Server configuration
PORT=3031

# Proxy configuration (optional, for accessing OKX API)
# HTTPS_PROXY=http://127.0.0.1:7890

# Email configuration
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-password

# Freqtrade dry-run API (keep the service bound to localhost)
FREQTRADE_API_URL=http://127.0.0.1:8091
# Prefer a long-lived token. Otherwise set the API credentials below.
# FREQTRADE_API_TOKEN=
# FREQTRADE_API_USER=freqtrader
# FREQTRADE_API_PASSWORD=replace-me

# Automatic plan approval is disabled unless explicitly enabled in dry-run.
TRADING_DRY_RUN=false
TRADING_DRY_RUN_EQUITY=10000
TRADING_RISK_FRACTION=0.005
# Execution is opt-in and still guarded by TRADING_DRY_RUN=true.
TRADING_EXECUTION_ENABLED=false
